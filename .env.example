# Railway env vars for Meridian
# After `make deploy-devnet && make setup-devnet`, fill in USDC_MINT from output.
# Then: grep -v '^#' .env | xargs railway variables set

# Shared (bot worker + frontend build)
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
USDC_MINT=<from setup-devnet output>

# Frontend (Vite static site - VITE_ prefix required)
VITE_RPC_URL=https://api.devnet.solana.com
VITE_USDC_MINT=<same as USDC_MINT>
VITE_DEV_WALLET=true
