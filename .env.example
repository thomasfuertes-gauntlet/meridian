# Meridian Environment Variables
# Copy to .env or set in your shell for local development, devnet, or Railway deployment

# ============================================================================
# Local Development
# ============================================================================

# Local Solana validator RPC endpoint (used by Anchor)
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899

# Path to local admin wallet (used by Anchor to sign transactions)
ANCHOR_WALLET=.wallets/admin.json

# Run bots with synthetic prices instead of Pyth Hermes (useful outside market hours)
OFFLINE=1

# ============================================================================
# Devnet Deployment
# ============================================================================

# Devnet RPC endpoint - required for deploying and running on devnet
# Example: https://devnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>
DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>

# Devnet USDC mint address (created by setup-devnet.ts)
# This is the custom mint we control on devnet for testing
DEVNET_USDC_MINT=<shared devnet usdc mint>

# ============================================================================
# Frontend (Vite)
# ============================================================================

# Frontend RPC URL (can differ from backend RPC)
# Defaults to http://localhost:8899 for local dev, set for devnet
VITE_RPC_URL=http://localhost:8899

# Frontend USDC mint - injected into frontend/src/lib/local-config.json
# On devnet, use the same mint as DEVNET_USDC_MINT
VITE_USDC_MINT=<usdc mint>

# Enable dev wallet auto-signing on any environment (even devnet)
# Set to "true" for demo UX where wallets auto-sign transactions
VITE_DEV_WALLET=true

# Frontend signal server URL (for bots to read active-market signal)
# On Railway, this is the public URL of the bots service
VITE_SIGNAL_URL=http://localhost:8080

# ============================================================================
# Bot System
# ============================================================================

# USDC mint for bot transactions (loaded from env or frontend/src/lib/local-config.json)
USDC_MINT=<usdc mint>

# Scopes all bot activity to a single ticker for demo focus
# Examples: NVDA, MSFT, GOOGL, TSLA, META
DEMO_TICKER=NVDA

# Active market signal file path (written by signal-server, read by bots)
# In containers: /tmp/meridian-active-market.txt
# Bots read this to weight 80% activity toward the user's current market
ACTIVE_MARKET=/tmp/meridian-active-market.txt

# ============================================================================
# Automation / Signal Server
# ============================================================================

# HTTP server port for signal-server (receives active-market signals from frontend)
# Railway sets this automatically; defaults to 8080 for local
PORT=8080

# Webhook URL for alerting (future feature for monitoring market events)
# Example: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_WEBHOOK_URL=<slack webhook or other service>

# ============================================================================
# Railway Deployment
# ============================================================================

# Railway service names for coordinating frontend + bots deployment
RAILWAY_FRONTEND_SERVICE=frontend
RAILWAY_BOTS_SERVICE=bots

# Public URL of the bots service (for VITE_SIGNAL_URL on Railway)
# Set by Railway during deployment; used by frontend to send active-market signals
RAILWAY_BOTS_PUBLIC_URL=https://your-railway-bots-domain.railway.app
