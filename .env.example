# Railway env vars for Meridian.
# Preferred flow:
#   cp config/devnet.env.example config/devnet.env
#   edit config/devnet.env
#   make railway-sync
# This file is only a flat export reference if you want to set vars manually.

ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>
USDC_MINT=<shared devnet usdc mint>
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>
VITE_USDC_MINT=<shared devnet usdc mint>
VITE_DEV_WALLET=true
