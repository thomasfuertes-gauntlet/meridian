# Meridian devnet operator config. Copy to .env and fill in values.
# Never commit .env — it is gitignored.

# Required: Devnet RPC endpoint (Helius, QuickNode, or public devnet)
DEVNET_RPC_URL=https://api.devnet.solana.com

# Required: USDC mint address on devnet (set by setup-devnet.ts, printed after setup)
DEVNET_USDC_MINT=

# ── Optional (all have defaults) ──────────────────────────────────

# Railway service name (default: meridian)
# RAILWAY_SERVICE=meridian

# Show dev wallet in frontend wallet picker (default: true)
# VITE_DEV_WALLET=true

# Scope bot activity to a single ticker (default: NVDA)
# DEMO_TICKER=NVDA

# Bot feature flags — disabled by default, set to "true" to enable
# ENABLE_LIQUIDITY_BOT=false
# ENABLE_TRADE_BOTS=false

# Wallet derivation mode: "deterministic" = sha256("meridian-dev-{name}") keys
# shared across all clones; "generate" = random keypairs (used by devnet-bootstrap)
# WALLET_MODE=deterministic

# Pyth Hermes endpoint for devnet-compatible Wormhole VAAs
# HERMES_URL=https://hermes-beta.pyth.network

# Override wallet paths (defaults to .wallets/ deterministic keys)
# ADMIN_WALLET=.wallets/admin.json
# PROGRAM_KEYPAIR=target/deploy/meridian-keypair.json
