# Meridian devnet operator config. Copy to .env and fill in values.
# Never commit .env — it is gitignored.

# Required: Devnet RPC endpoint (Helius, QuickNode, or public devnet)
DEVNET_RPC_URL=https://api.devnet.solana.com

# Required: USDC mint address on devnet (set by setup-devnet.ts, printed after setup)
DEVNET_USDC_MINT=

# Optional: Pyth Hermes endpoint for devnet-compatible Wormhole VAAs
# HERMES_URL=https://hermes-beta.pyth.network
