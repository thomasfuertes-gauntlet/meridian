gm.local.md
.claude/
.env
frontend/.env.local

# TypeScript build artifacts (tsc -b emits in-place without outDir)
tsconfig.tsbuildinfo
*.tsbuildinfo
scripts/*.js
tests/*.js
automation/src/*.js
app/vite.config.js

# Anchor / Solana (target/* ignores contents, not the dir itself, so negations work)
target/*
!target/types/
!target/idl/
target/types/*.js
.anchor/
test-ledger/
.localnet/
.wallets/
node_modules/

# Local dev (session-specific, regenerated by make setup)
app/src/lib/local-config.json

# ZKP build intermediates (regenerated by circuits/build.sh and make tree)
circuits/build/
circuits/node_modules/
app/public/zkp/tree.json
*.ptau
# brag.zkey, brag_wasm/, and vkey.json are tracked (portable, needed by frontend)
