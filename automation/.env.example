# Solana RPC endpoint (devnet)
RPC_URL=https://api.devnet.solana.com

# Path to admin keypair JSON file
ADMIN_KEYPAIR_PATH=~/.config/solana/id.json

# USDC mint address (devnet custom mint)
USDC_MINT=

# Meridian program ID
PROGRAM_ID=G8kuCKKgU3uTswZPzkP5iXhSWd15ejKgnpr9atJx7azD

# Pyth Hermes endpoint
HERMES_URL=https://hermes.pyth.network

# Override feed IDs (optional, JSON object mapping ticker to hex feed ID)
# PYTH_FEED_OVERRIDES={"AAPL":"49f6b65cb1..."}
