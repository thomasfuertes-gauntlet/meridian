# Single RPC URL for all devnet operations.
# Makefile reads this as DEVNET_RPC_URL to build DEVNET_URL.
# railway-sync pushes it as ANCHOR_PROVIDER_URL; entrypoint.sh derives RPC_URL from it.
# VITE_RPC_URL is a separate build-time bake - set it to the same value in Railway.
DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>
DEVNET_USDC_MINT=<shared devnet usdc mint>
RAILWAY_SERVICE=meridian
VITE_DEV_WALLET=true
DEMO_TICKER=NVDA

# Override deterministic wallet paths (optional - defaults to .wallets/ deterministic keys)
# ADMIN_WALLET=.wallets/admin.json
# BOT_A_WALLET=.wallets/bot-a.json
# BOT_B_WALLET=.wallets/bot-b.json
# PROGRAM_KEYPAIR=target/deploy/meridian-keypair.json

# Frontend keypair seed overrides (hex strings, optional)
# VITE_ADMIN_SEED=<hex-encoded-32-byte-seed>
# VITE_BOT_B_SEED=<hex-encoded-32-byte-seed>
